# Auth.js / NextAuth — required for production. Generate: openssl rand -base64 32
AUTH_SECRET=

# Optional; defaults to http://localhost:3000 in dev
# AUTH_URL=http://localhost:3000

# Board chat (Socket.io). Run: bun run socket — default http://localhost:3001
# NEXT_PUBLIC_CHAT_SOCKET_URL=http://localhost:3001
# SOCKET_CHAT_PORT=3001

# LiveKit (voice/video). Create a project at https://cloud.livekit.io — never commit real secrets.
# Browser WebSocket URL (same as LIVEKIT_URL if you use wss://)
# NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
# Server token + Room API (optional duplicate of URL for server-only env)
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
