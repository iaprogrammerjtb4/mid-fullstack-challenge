# Auth.js / NextAuth — required for production. Generate: openssl rand -base64 32
AUTH_SECRET=

# Public URL of the app (required in production, e.g. Vercel). No trailing slash.
# Dev default is http://localhost:3000 if unset.
# AUTH_URL=https://your-project.vercel.app

# --- Producción en Vercel (base compartida) ---
# Si defines ambas, la app usa Turso (libSQL) en lugar del archivo SQLite local.
# Crea una DB en https://turso.tech y copia URL + token.
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# Solo con Turso: insertar pm@ / dev@ (password123) si la tabla users está vacía (útil para demo).
# TURSO_SEED_DEMO=1

# Con Turso: no insertar usuarios demo aunque TURSO_SEED_DEMO=1
# TURSO_SKIP_DEMO_USERS=1

# Vercel sin Turso: SQLite en /tmp; demo users si users está vacío. Desactivar:
# VERCEL_SKIP_DEMO_USERS=1

# Board chat (Socket.io). Run: bun run socket — default http://localhost:3001
# NEXT_PUBLIC_CHAT_SOCKET_URL=http://localhost:3001
# SOCKET_CHAT_PORT=3001

# LiveKit (voice/video). Create a project at https://cloud.livekit.io — never commit real secrets.
# Browser WebSocket URL (same as LIVEKIT_URL if you use wss://)
# NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
# Server token + Room API (optional duplicate of URL for server-only env)
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
